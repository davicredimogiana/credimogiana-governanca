# ─── Configurações do Banco de Dados ─────────────────────────────────────────
POSTGRES_PASSWORD=sua_senha_segura_aqui

# ─── URL da API (acessível pelo navegador do usuário final) ───────────────────
# Em produção, use o domínio público do backend
# Ex: https://api.seudominio.com.br
VITE_API_URL=http://localhost:5000

# ─── URL base do backend (usada internamente pelo Worker N8N) ────────────────
# Deve apontar para o serviço backend dentro da rede Docker.
# Em produção, use o domínio público do backend.
# Ex: https://api.seudominio.com.br
API_CALLBACK_BASE_URL=http://backend:5000
